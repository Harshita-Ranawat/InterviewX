PORT=5050

# Comma-separated browser origins allowed to call the API (CORS).
# Local dev (Vite):
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# Production (Render dashboard) — live frontend: https://intervue-x-inky.vercel.app
# Paste these on Render (no trailing slash on origins):
#   CLIENT_ORIGIN=https://intervue-x-inky.vercel.app,http://localhost:5173,http://localhost:5174
#   APP_PUBLIC_URL=https://intervue-x-inky.vercel.app

# Public URL of the **frontend** (invite links, Gmail OAuth redirect).
# Must match an authorized redirect URI in Google Cloud: {APP_PUBLIC_URL}/oauth/gmail-invite
APP_PUBLIC_URL=http://localhost:5173

MONGODB_URI=
OPENAI_API_KEY=

# Firebase Admin — pick ONE:
# • Local: path to the JSON key file (never commit the file).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# • Render / other hosts: paste the **entire** service account JSON as one line (minified).
#   Create key: Firebase Console → Project settings → Service accounts → Generate new private key.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

INVITE_SMTP_SECRET=

# Gmail OAuth (invite mail). From Google Cloud → APIs & Services → Credentials (Web client).
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=

# Optional platform-wide SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
