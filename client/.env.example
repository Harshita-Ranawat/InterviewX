# --- Local dev (Vite) ---
# Leave empty: `/api` and `/socket.io` are proxied (see vite.config.js → VITE_DEV_PROXY_TARGET).
VITE_API_BASE=

# Optional: dev server port (match server CLIENT_ORIGIN for this port).
# VITE_DEV_PORT=5174

# Express API URL during dev (proxy target).
# VITE_DEV_PROXY_TARGET=http://localhost:4000

# --- Production (Vercel) ---
# Set in Vercel → Settings → Environment Variables, OR rely on `.env.production` in the repo.
# Your deployed Render backend (no trailing slash):
# VITE_API_BASE=https://intervuex-1wwc.onrender.com

# After deploying, add intervue-x-inky.vercel.app to Firebase → Authentication → Settings → Authorized domains.
# On Render, set CLIENT_ORIGIN and APP_PUBLIC_URL to https://intervue-x-inky.vercel.app (see server/.env.example).

# Firebase (web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
